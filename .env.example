# Address Parse Service

PORT=8080
MODE=debug

# PostgreSQL
DATABASE_URL=postgres://postgres:postgres@localhost:5432/address_parse

# Redis
REDIS_URL=redis://localhost:6379

# LLM (DashScope / 通义千问)
DASHSCOPE_API_KEY=your-dashscope-api-key
LLM_MODEL=qwen-turbo
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Geocoding (高德地图) — used as fallback when street→district lookup fails
# Get your key at: https://console.amap.com/dev/key/app
GEOCODER_API_KEY=your-amap-api-key
GEOCODER_BASE_URL=https://restapi.amap.com/v3

# Auth (comma-separated app IDs and secrets)
APP_IDS=client_001
APP_SECRETS=secret1

# Rate limits (requests per window)
RATE_LIMIT_GLOBAL=5000
RATE_LIMIT_APP=500
RATE_LIMIT_IP=1000
